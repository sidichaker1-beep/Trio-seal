<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>TRIO SEAL · Cosmic Observatory</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
<style>
:root{
  --bg:#0a0f1a; --card:rgba(10,24,52,0.88); --bdr:rgba(255,215,0,.25); --gold:#ffd700; --gold-dim:rgba(255,215,0,.10);
  --live:#4ade80; --alert:#ef4444; --warn:#f97316; --yellow:#eab308; --muted:#94a3b8; --glow:0 0 22px rgba(255,215,0,.35);
  --r:18px; --r-pill:60px; --t:all .3s ease;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--bg);color:#f1f5f9;font-family:'Orbitron',sans-serif;min-height:100vh;padding:18px 18px 72px;overflow-x:hidden;}
body::before{
  content:'';position:fixed;inset:0;
  background:
    radial-gradient(1.5px 1.5px at  7% 11%,#fff,transparent),
    radial-gradient(1.5px 1.5px at 21% 43%,#fff,transparent),
    radial-gradient(1px 1px at 54%  7%,#fff,transparent),
    radial-gradient(1.5px 1.5px at 67% 71%,#fff,transparent),
    radial-gradient(1px 1px at 82% 24%,#fff,transparent),
    radial-gradient(1px 1px at 11% 79%,#fff,transparent),
    radial-gradient(1.5px 1.5px at 37% 90%,#fff,transparent),
    radial-gradient(1px 1px at 91% 54%,#fff,transparent),
    radial-gradient(1px 1px at 48% 33%,#fff,transparent),
    radial-gradient(1.5px 1.5px at 73% 16%,#fff,transparent);
  background-size:220px 220px;opacity:.2;pointer-events:none;z-index:0;
}
.container{max-width:1400px;margin:0 auto;position:relative;z-index:1}
/* CARD BASE */
.card{background:var(--card);backdrop-filter:blur(12px);border:1px solid var(--bdr);border-radius:var(--r);transition:var(--t);position:relative;overflow:hidden;}
.card::before{content:'';position:absolute;top:0;left:-110%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.06),transparent);transition:left .55s ease;pointer-events:none;}
.card[data-link]{cursor:pointer}
.card[data-link]:hover{transform:translateY(-5px) scale(1.015);border-color:var(--gold);box-shadow:var(--glow)}
.card[data-link]:hover::before{left:110%}
/* HEADER */
.header{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:14px;padding:14px 24px;margin-bottom:16px;border-radius:var(--r-pill);}
.logo{font-size:1.8rem;font-weight:900;color:var(--gold);text-shadow:0 0 14px rgba(255,215,0,.6);text-decoration:none;cursor:pointer;user-select:none;transition:transform .2s;display:inline-block;}
.logo:hover{transform:scale(1.07)}
.hdr-time{display:flex;gap:1.4rem;flex-wrap:wrap;font-family:'Share Tech Mono',monospace;font-size:.9rem}
.hdr-time span{color:var(--live)}
.lang-wrap{position:relative}
.lang-btn{background:var(--gold-dim);border:1px solid var(--bdr);color:var(--gold);padding:6px 14px;border-radius:8px;cursor:pointer;font-family:'Orbitron',sans-serif;font-size:.78rem;display:flex;align-items:center;gap:6px;transition:background .2s;}
.lang-btn:hover{background:rgba(255,215,0,.2)}
.lang-menu{position:absolute;top:calc(100% + 6px);right:0;background:rgba(8,18,42,.96);backdrop-filter:blur(14px);border:1px solid var(--bdr);border-radius:10px;display:none;z-index:300;min-width:130px;overflow:hidden;}
.lang-menu.open{display:block}
.lang-opt{padding:10px 16px;cursor:pointer;font-size:.82rem;border-bottom:1px solid rgba(255,215,0,.12);transition:background .15s}
.lang-opt:last-child{border-bottom:none}
.lang-opt:hover{background:rgba(255,215,0,.14)}
/* TICKER */
.ticker-wrap{border-radius:10px;padding:9px 20px;margin-bottom:16px;overflow:hidden;white-space:nowrap}
.ticker-inner{display:inline-block;animation:marquee 38s linear infinite;font-size:.85rem;color:var(--live)}
.ticker-inner span{margin-right:48px;color:#fff}
@keyframes marquee{0%{transform:translateX(100vw)}100%{transform:translateX(-100%)}}
/* TIME BAR */
#time-bar{display:flex;justify-content:space-around;flex-wrap:wrap;gap:10px;padding:12px 24px;margin-bottom:18px;border-radius:var(--r-pill);font-family:'Share Tech Mono',monospace;font-size:.9rem;}
#time-bar .utc{color:var(--live)}
#time-bar .mecca{color:var(--gold)}
/* GRIDS */
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-bottom:18px}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin-bottom:18px}
@media(max-width:1100px){.grid-4{grid-template-columns:repeat(2,1fr)}}
@media(max-width:768px){.grid-3,.grid-4{grid-template-columns:1fr}}
/* OBS CARDS */
.obs-card{padding:1.4rem;min-height:230px;display:flex;flex-direction:column;gap:6px}
.obs-title{color:var(--gold);font-size:1rem;font-weight:600}
.obs-value{font-size:2rem;font-weight:700;color:var(--live);font-family:'Share Tech Mono',monospace;transition:color .4s}
.obs-unit{color:var(--muted);font-size:.75rem}
.obs-desc{color:var(--muted);font-size:.78rem;margin-top:auto;line-height:1.5}
.gauge-track{height:6px;background:rgba(255,255,255,.08);border-radius:99px;overflow:hidden;margin:6px 0}
.gauge-fill{height:100%;border-radius:99px;transition:width .6s cubic-bezier(.4,0,.2,1),background .4s;width:0%}
.g-gold{background:linear-gradient(90deg,#f1c40f,#d4a017)}
.g-blue{background:linear-gradient(90deg,#3b82f6,#1d4ed8)}
.g-green{background:linear-gradient(90deg,#22c55e,#16a34a)}
.g-red{background:linear-gradient(90deg,#ef4444,#b91c1c)}
.g-orange{background:linear-gradient(90deg,#f97316,#ea580c)}
.obs-image{width:100%;height:120px;object-fit:cover;border-radius:10px;margin-bottom:.75rem;border:1px solid var(--bdr);background:rgba(255,215,0,.04)}
.obs-image[data-error]{opacity:.3;filter:grayscale(1)}
/* MOON */
.moon-card{display:flex;align-items:center;gap:2.5rem;flex-wrap:wrap;padding:2rem 2.5rem;margin-bottom:18px;cursor:pointer}
.moon-emoji{font-size:5rem;line-height:1;transition:transform .3s}
.moon-card:hover .moon-emoji{transform:scale(1.1)}
.moon-info{flex:1}
.moon-name{font-size:1.4rem;font-weight:700;color:var(--gold);margin-bottom:1rem}
.moon-stats{display:flex;gap:2.5rem;flex-wrap:wrap}
.moon-stat .val{font-size:1.5rem;font-weight:700;color:var(--live);font-family:'Share Tech Mono',monospace}
.moon-stat .lbl{color:var(--muted);font-size:.75rem}
/* SECTION TITLES */
.section-title{color:var(--gold);font-size:1.6rem;margin:1.8rem 0 1rem;text-shadow:0 0 12px rgba(255,215,0,.25)}
/* FOOTER */
.footer{margin:2.5rem 0 1rem;padding:1.5rem;text-align:center;cursor:pointer}
.footer .name{color:var(--gold);font-weight:700;font-size:1.05rem}
.footer .sub{color:var(--muted);font-size:.82rem;margin:6px 0}
.footer a{color:var(--live);text-decoration:none}
.footer a:hover{text-decoration:underline}
/* BOTTOM TICKER */
.bticker{position:fixed;bottom:0;left:0;width:100%;background:rgba(8,14,28,.97);backdrop-filter:blur(14px);border-top:1px solid var(--bdr);padding:9px 0;overflow:hidden;white-space:nowrap;z-index:1000}
.bticker-inner{display:inline-block;animation:marquee 55s linear infinite;font-size:.84rem}
.bticker-inner .ti{display:inline-block;margin-right:48px;color:#fff}
.bticker-inner .ti i{color:var(--gold);margin-right:5px}
.bticker-inner .ti b{color:var(--live)}
</style>
</head>
<body>
<div class="container">

<header class="header card">
  <a class="logo" href="https://github.com/sidichaker1-beep/Trio-seal" target="_blank" rel="noopener">🌌 TRIO SEAL</a>
  <div class="hdr-time">
    <span id="h-date">📅 --</span>
    <span id="h-utc">🌐 00:00:00</span>
    <span id="h-mecca">🕋 00:00:00</span>
  </div>
  <div class="lang-wrap">
    <button class="lang-btn" id="langBtn">🌐 <span id="cur-lang">EN</span> ▾</button>
    <div class="lang-menu" id="langMenu">
      <div class="lang-opt" data-lang="en">🇬🇧 English</div>
      <div class="lang-opt" data-lang="ar">🇸🇦 العربية</div>
    </div>
  </div>
</header>

<div class="ticker-wrap card">
  <div class="ticker-inner" id="topTicker"></div>
</div>

<div id="time-bar" class="card"></div>

<div class="grid-3" id="obsGrid"></div>

<div class="section-title">🌕 Moon & Lunar Data</div>
<div class="grid-3" id="moonGrid"></div>

<div class="section-title">🌞 Solar Activity</div>
<div class="grid-3" id="solarGrid"></div>

<div class="section-title">🌋 Volcanoes</div>
<div class="grid-3" id="volcanoGrid"></div>

<div class="section-title">🌐 Earthquakes</div>
<div class="grid-3" id="quakeGrid"></div>

<div class="footer card">
  <div class="name">TRIO SEAL · Cosmic Observatory</div>
  <div class="sub">Live Observatory Dashboard · All Rights Reserved 2026</div>
  <div><a href="https://github.com/sidichaker1-beep/Trio-seal" target="_blank">Source & Updates</a></div>
</div>

<div class="bticker card">
  <div class="bticker-inner" id="bticker"></div>
</div>

<script>
// Utility
const $=id=>document.getElementById(id);
const p2=v=>String(v).padStart(2,'0');
function setText(id,v){const e=$(id);if(e)e.textContent=v;}
function setGauge(id,pct,cls){const e=$(id);if(!e)return;e.style.width=Math.max(0,Math.min(pct,100))+'%';e.className='gauge-fill '+cls;}

// Lang Menu
const langBtn=$('langBtn'), langMenu=$('langMenu'), curLang=$('cur-lang');
langBtn.addEventListener('click',()=>langMenu.classList.toggle('open'));
langMenu.querySelectorAll('.lang-opt').forEach(o=>{
  o.addEventListener('click',()=>{
    curLang.textContent=o.dataset.lang.toUpperCase();
    langMenu.classList.remove('open');
  });
});

// Clock
function updateTime(){
  const now=new Date();
  const mecca=new Date(new Date().toLocaleString('en-US',{timeZone:'Asia/Riyadh'}));
  const utc=`${p2(now.getUTCHours())}:${p2(now.getUTCMinutes())}:${p2(now.getUTCSeconds())}`;
  const mkt=`${p2(mecca.getHours())}:${p2(mecca.getMinutes())}:${p2(mecca.getSeconds())}`;
  const ds=now.toLocaleDateString('en-US',{year:'numeric',month:'short',day:'numeric'});
  setText('h-date','📅 '+ds); setText('h-utc','🌐 '+utc); setText('h-mecca','🕋 '+mkt);
  $('time-bar').innerHTML=`<div>📅 ${ds}</div><div class="utc">🌐 UTC: ${utc}</div><div class="mecca">🕋 Mecca: ${mkt}</div>`;
}
setInterval(updateTime,500); updateTime();

// Ticker
const tickerMsgs=[
  "🌋 Fuego Volcano — WARNING level active",
  "🌀 Solar activity moderate · C-class flares",
  "📡 USGS live feed · updates every 30s",
  "🕋 Mizan al-Malakut v7.3 · Critical RS=0.0057",
  "🌕 Moon phase computed via synodic algorithm",
  "⚡ All observatory systems nominal"
];
$('topTicker').innerHTML=tickerMsgs.map(s=>`<span>${s}</span>`).join('');

// Observatories Example Data
const obsIndicators=[
  {title:'🕋 Taqābul',unit:'° — Mecca angle',val:42,gauge:'g-gold',desc:'Angular alignment to Mecca'},
  {title:'🌀 Closure Index',unit:'0–1 Resonance',val:0.57,gauge:'g-blue',desc:'System resonance metric'},
  {title:'⚖️ Balance Index',unit:'0–1 α deviation',val:0.72,gauge:'g-green',desc:'Stability metric'}
];
const grids={obs:'obsGrid',moon:'moonGrid',solar:'solarGrid',volcano:'volcanoGrid',quake:'quakeGrid'};
function fillGrid(id,data){
  const grid=$(id); grid.innerHTML='';
  data.forEach(d=>{
    const c=document.createElement('div'); c.className='obs-card card';
    if(d.link)c.setAttribute('data-link',d.link);
    c.innerHTML=`<span class="obs-title">${d.title}</span>
      <span class="obs-value">${d.val}</span>
      <span class="obs-unit">${d.unit}</span>
      <div class="gauge-track"><div class="gauge-fill ${d.gauge}" style="width:${d.val*100/100}%"></div></div>
      <span class="obs-desc">${d.desc}</span>`;
    grid.appendChild(c);
  });
}
fillGrid('obsGrid',obsIndicators);

// Clickable cards
document.querySelectorAll('.card[data-link]').forEach(c=>{
  c.addEventListener('click',()=>window.open(c.dataset.link,'_blank','noopener'));
});

// Bottom Ticker
$('bticker').innerHTML=tickerMsgs.map(s=>`<span class="ti"><i class="fa-solid fa-star"></i> ${s}</span>`).join('');
</script>

</div>
</body>
</html>
