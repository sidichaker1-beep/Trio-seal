<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TRIO SEAL · Cosmic Observatory</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-dark: #0a0f1a;
            --card-bg: rgba(15, 43, 79, 0.85);
            --card-border: rgba(255, 215, 0, 0.3);
            --text-glow: #ffd700;
            --text-live: #4ade80;
            --text-alert: #ef4444;
            --text-warning: #f97316;
            --text-yellow: #eab308;
            --text-secondary: #94a3b8;
            --shadow-glow: 0 0 20px rgba(255, 215, 0, 0.3);
            --shadow-red: 0 0 20px rgba(239, 68, 68, 0.3);
        }

        body {
            background: var(--bg-dark);
            color: #fff;
            font-family: 'Orbitron', sans-serif;
            min-height: 100vh;
            padding: 20px;
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(2px 2px at 20px 30px, #fff, rgba(0,0,0,0)),
                        radial-gradient(2px 2px at 40px 70px, #fff, rgba(0,0,0,0)),
                        radial-gradient(2px 2px at 80px 120px, #fff, rgba(0,0,0,0));
            background-size: 200px 200px;
            opacity: 0.3;
            pointer-events: none;
            z-index: -1;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 2rem;
            margin-bottom: 2rem;
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
            border-radius: 15px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .logo {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-glow);
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
            cursor: pointer;
        }

        .logo:hover {
            transform: scale(1.05);
        }

        .time-info {
            display: flex;
            gap: 2rem;
            font-family: 'Courier New', monospace;
            color: var(--text-live);
        }

        .language-selector {
            position: relative;
        }

        .lang-btn {
            background: transparent;
            border: 1px solid var(--card-border);
            color: var(--text-glow);
            padding: 0.5rem 1rem;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-family: 'Orbitron', sans-serif;
            backdrop-filter: blur(5px);
        }

        .lang-menu {
            position: absolute;
            top: 100%;
            right: 0;
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
            border-radius: 8px;
            display: none;
            z-index: 100;
            min-width: 150px;
            margin-top: 5px;
        }

        .lang-option {
            padding: 0.7rem 1rem;
            cursor: pointer;
            border-bottom: 1px solid rgba(255, 215, 0, 0.2);
        }

        .lang-option:hover {
            background: rgba(255, 215, 0, 0.2);
        }

        .news-ticker {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
            border-radius: 10px;
            padding: 10px 20px;
            margin-bottom: 20px;
            overflow: hidden;
            white-space: nowrap;
            position: relative;
        }

        .news-ticker-content {
            display: inline-block;
            animation: ticker 30s linear infinite;
            color: var(--text-live);
        }

        .news-ticker-content span {
            margin-right: 30px;
            color: white;
        }

        @keyframes ticker {
            0% { transform: translateX(100%); }
            100% { transform: translateX(-100%); }
        }

        #cosmic-time-bar {
            display: flex;
            justify-content: space-around;
            padding: 12px 20px;
            margin-bottom: 20px;
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
            border-radius: 60px;
            font-family: 'Courier New', monospace;
            font-weight: bold;
            flex-wrap: wrap;
            gap: 10px;
        }

        #cosmic-time-bar span { color: white; }
        #cosmic-time-bar .utc-clock { color: var(--text-live); }
        #cosmic-time-bar .mecca-clock { color: var(--text-glow); }

        .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 20px; }
        .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 20px; }

        @media (max-width: 1200px) {
            .grid-4 { grid-template-columns: repeat(2, 1fr); }
        }
        @media (max-width: 768px) {
            .grid-3, .grid-4 { grid-template-columns: 1fr; }
        }

        .obs-card {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
            border-radius: 20px;
            padding: 1.5rem;
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            min-height: 250px;
            display: flex;
            flex-direction: column;
        }

        .obs-card img, .obs-card span, .obs-card div {
            pointer-events: none;
        }

        .obs-card[data-link] {
            cursor: pointer;
        }

        .obs-card[data-link]:hover {
            transform: translateY(-6px) scale(1.02);
            border-color: var(--text-glow);
            box-shadow: var(--shadow-glow);
        }

        .obs-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
            transition: left 0.5s ease;
        }

        .obs-card:hover::before { left: 100%; }

        .obs-image {
            width: 100%;
            height: 120px;
            object-fit: cover;
            border-radius: 10px;
            margin-bottom: 1rem;
            border: 1px solid var(--card-border);
        }

        .obs-title {
            color: var(--text-glow);
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .obs-value {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--text-live);
            margin-bottom: 0.3rem;
        }

        .obs-unit {
            color: var(--text-secondary);
            font-size: 0.8rem;
        }

        .moon-phase {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
            border-radius: 30px;
            padding: 2rem;
            margin: 2rem 0;
            display: flex;
            align-items: center;
            gap: 3rem;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .moon-phase:hover {
            border-color: var(--text-glow);
            box-shadow: var(--shadow-glow);
        }

        .moon-icon {
            font-size: 5rem;
            transition: all 0.3s ease;
        }

        .moon-stats { flex: 1; }
        .moon-title { font-size: 1.5rem; font-weight: 700; color: var(--text-glow); margin-bottom: 1rem; }
        .moon-grid { display: flex; gap: 3rem; flex-wrap: wrap; }
        .moon-item { text-align: center; }
        .moon-item .value { font-size: 1.5rem; font-weight: 700; color: var(--text-live); }
        .moon-item .label { color: var(--text-secondary); font-size: 0.8rem; }

        .volcano-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .volcano-stat {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 15px;
            padding: 1rem;
            text-align: center;
            cursor: pointer;
        }

        .volcano-stat .number { font-size: 2rem; font-weight: bold; color: var(--text-glow); }

        .volcano-list {
            max-height: 350px;
            overflow-y: auto;
            scrollbar-width: thin;
        }
        
        .volcano-list::-webkit-scrollbar {
            width: 6px;
        }
        
        .volcano-list::-webkit-scrollbar-track {
            background: var(--card-bg);
            border-radius: 3px;
        }
        
        .volcano-list::-webkit-scrollbar-thumb {
            background: var(--text-glow);
            border-radius: 3px;
        }
        
        .volcano-item {
            background: rgba(0, 0, 0, 0.4);
            border-radius: 12px;
            padding: 0.8rem 1rem;
            margin-bottom: 0.6rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            border-left: 4px solid;
            cursor: pointer;
            transition: all 0.2s ease;
        }
        
        .volcano-item:hover {
            transform: translateX(5px);
            background: rgba(255, 215, 0, 0.1);
        }
        
        .volcano-name {
            flex: 1;
            font-family: 'Orbitron', monospace;
            font-size: 0.9rem;
        }
        
        .volcano-status {
            font-size: 0.7rem;
            padding: 2px 8px;
            border-radius: 20px;
            background: rgba(0, 0, 0, 0.3);
            font-weight: bold;
        }

        .earthquake-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .quake-stat {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 15px;
            padding: 1rem;
            text-align: center;
            cursor: pointer;
        }

        .quake-stat .number { font-size: 2rem; font-weight: bold; color: var(--text-glow); }

        .quake-list {
            max-height: 300px;
            overflow-y: auto;
            margin-bottom: 1rem;
        }

        .quake-item {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 12px;
            padding: 0.8rem 1rem;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            border-left: 5px solid;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .quake-item:hover { transform: translateX(5px); }
        .quake-magnitude { font-size: 1.4rem; font-weight: bold; min-width: 60px; }
        .quake-location { flex: 1; }
        .quake-time { color: var(--text-secondary); font-size: 0.8rem; }

        .bottom-ticker {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border-top: 1px solid var(--card-border);
            padding: 10px 0;
            overflow: hidden;
            white-space: nowrap;
            z-index: 1000;
        }

        .ticker-content {
            display: inline-block;
            animation: ticker 40s linear infinite;
        }

        .ticker-item {
            display: inline-block;
            margin-right: 40px;
            color: white;
            font-size: 0.9rem;
            cursor: pointer;
        }

        .ticker-item i { margin-right: 5px; color: var(--text-glow); }
        .ticker-item span { color: var(--text-live); font-weight: bold; }

        .footer {
            margin-top: 4rem;
            padding: 1.5rem;
            text-align: center;
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
            border-radius: 20px;
            margin-bottom: 60px;
            cursor: pointer;
        }

        .footer .name { color: var(--text-glow); font-weight: 700; }
        .footer a { color: var(--text-live); text-decoration: none; }

        .section-title {
            color: var(--text-glow);
            font-size: 1.8rem;
            margin: 2rem 0 1rem;
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo" data-link="https://github.com/sidichaker1-beep/Trio-seal">🌌 TRIO SEAL</div>
            <div class="time-info">
                <span id="gregorian-date">📅 --</span>
                <span id="utc-clock">🌐 00:00:00</span>
                <span id="mecca-clock">🕋 00:00:00</span>
            </div>
            <div class="language-selector">
                <button class="lang-btn" onclick="toggleLanguageMenu()">
                    🌐 <span id="current-lang">EN</span> <span style="font-size:0.8rem;">▼</span>
                </button>
                <div id="language-menu" class="lang-menu">
                    <div class="lang-option" onclick="setLanguage('en')">🇬🇧 EN</div>
                    <div class="lang-option" onclick="setLanguage('ar')">🇸🇦 AR</div>
                </div>
            </div>
        </div>

        <div class="news-ticker">
            <div class="news-ticker-content" id="news-ticker"></div>
        </div>

        <div id="cosmic-time-bar">
            <div>📅 <span id="gregorian-date-full">--</span> · <span id="hijri-date">--</span></div>
            <div>🌐 UTC: <span class="utc-clock" id="utc-clock-full">00:00:00</span></div>
            <div>🕋 Mecca: <span class="mecca-clock" id="mecca-clock-full">00:00:00</span></div>
        </div>

        <div class="grid-3">
            <div class="obs-card" data-link="https://www.timeanddate.com/astronomy/moon/mecca.html">
                <span class="obs-title">🕋 Taqābul</span>
                <span class="obs-value" id="taqabul-value">23.50</span>
                <span class="obs-unit">Angle</span>
            </div>
            <div class="obs-card" data-link="https://earthquake.usgs.gov">
                <span class="obs-title">🌀 Closure</span>
                <span class="obs-value" id="closure-value">0.842</span>
                <span class="obs-unit">RS</span>
            </div>
            <div class="obs-card" data-link="https://www.noaa.gov">
                <span class="obs-title">⚖️ Balance</span>
                <span class="obs-value" id="balance-value">1.270</span>
                <span class="obs-unit">α_stab</span>
            </div>
        </div>

        <div class="moon-phase" id="moon-card" data-link="https://www.timeanddate.com/moon/">
            <div class="moon-icon" id="moon-icon">🌑</div>
            <div class="moon-stats">
                <div class="moon-title" id="moon-phase-name">New Moon</div>
                <div class="moon-grid">
                    <div class="moon-item">
                        <div class="value" id="moon-illumination">0%</div>
                        <div class="label">Illumination</div>
                    </div>
                    <div class="moon-item">
                        <div class="value" id="moon-thickness">0'</div>
                        <div class="label">Thickness</div>
                    </div>
                    <div class="moon-item">
                        <div class="value" id="moon-age">0d</div>
                        <div class="label">Age</div>
                    </div>
                </div>
            </div>
        </div>

        <h2 class="section-title">☀️ Solar Observatory</h2>
        <div class="grid-4">
            <div class="obs-card" data-link="https://services.swpc.noaa.gov/json/ovation_aurora_latest.json">
                <img class="obs-image" id="aurora-img" src="https://services.swpc.noaa.gov/images/aurora-forecast/latest.jpg" alt="Aurora">
                <span class="obs-title">Aurora Oval</span>
            </div>
            <div class="obs-card" data-link="https://www.swpc.noaa.gov/products/planetary-k-index">
                <img class="obs-image" id="kp-img" src="https://services.swpc.noaa.gov/images/planetary-k-index.gif" alt="Kp">
                <span class="obs-title">Kp Index</span>
            </div>
            <div class="obs-card" data-link="https://solarham.com/cmetracking.htm">
                <img class="obs-image" id="cme-img" src="https://solarham.com/images/cme_latest.png" alt="CME">
                <span class="obs-title">CME Tracking</span>
            </div>
            <div class="obs-card" data-link="https://www.swpc.noaa.gov/products/goes-x-ray-flux">
                <img class="obs-image" id="xray-img" src="https://services.swpc.noaa.gov/images/goes-xray-flux-latest.png" alt="X-Ray">
                <span class="obs-title">X-Ray Flux</span>
            </div>
        </div>

        <div class="obs-card" data-link="https://sdo.gsfc.nasa.gov/data/" style="margin: 1rem 0;">
            <img class="obs-image" id="daily-solar-img" src="https://sdo.gsfc.nasa.gov/assets/img/latest/latest_512_1024.jpg" alt="Daily Solar">
            <span class="obs-title">☀️ Today's Sun</span>
        </div>

        <h2 class="section-title">🌋 Live Volcano Observatory</h2>
        <div class="obs-card" data-link="https://volcano.si.edu/">
            <div class="volcano-stats">
                <div class="volcano-stat"><span class="number" id="volcano-total">0</span><div>Active Volcanoes</div></div>
                <div class="volcano-stat"><span class="number" id="volcano-alert">0</span><div>High Alert</div></div>
            </div>
            <div id="volcano-list" class="volcano-list"></div>
        </div>

        <h2 class="section-title">🌋 Live Earthquake Observatory</h2>
        <div class="obs-card" data-link="https://earthquake.usgs.gov/earthquakes/map/">
            <div class="earthquake-stats">
                <div class="quake-stat"><span class="number" id="quake-total">0</span><div>Total</div></div>
                <div class="quake-stat"><span class="number" id="quake-strongest">0</span><div>Strongest</div></div>
                <div class="quake-stat"><span class="number" id="quake-latest">0</span><div>Latest</div></div>
            </div>
            <div id="quake-list" class="quake-list"></div>
        </div>

        <div class="footer" data-link="https://github.com/sidichaker1-beep/Trio-seal">
            <div class="name">Hicham Chigar · هشام شيكر</div>
            <div style="margin: 0.5rem 0;">Mizan al-Malakut v7.3 · Calibrated by Gemini · DeepSeek · GPT</div>
            <div>DOI: <a href="https://doi.org/10.5281/zenodo.19076840" target="_blank">10.5281/zenodo.19076840</a></div>
        </div>
    </div>

    <div class="bottom-ticker">
        <div class="ticker-content" id="bottom-ticker"></div>
    </div>

    <script>
        // Golden Volcano List
        const GOLDEN_VOLCANOES = [
            { name: "Etna", country: "Italy", alert: "orange", status: "WATCH", url: "https://volcano.si.edu/volcano.cfm?vn=211060" },
            { name: "Kilauea", country: "Hawaii, USA", alert: "orange", status: "WATCH", url: "https://volcano.si.edu/volcano.cfm?vn=332010" },
            { name: "Fuego", country: "Guatemala", alert: "red", status: "WARNING", url: "https://volcano.si.edu/volcano.cfm?vn=342090" },
            { name: "Sakurajima", country: "Japan", alert: "orange", status: "WATCH", url: "https://volcano.si.edu/volcano.cfm?vn=282080" },
            { name: "Popocatépetl", country: "Mexico", alert: "yellow", status: "ADVISORY", url: "https://volcano.si.edu/volcano.cfm?vn=341090" },
            { name: "Great Sitkin", country: "Alaska, USA", alert: "orange", status: "WATCH", url: "https://avo.alaska.edu/volcano/Great_Sitkin" },
            { name: "Merapi", country: "Indonesia", alert: "yellow", status: "ADVISORY", url: "https://volcano.si.edu/volcano.cfm?vn=263250" },
            { name: "Semeru", country: "Indonesia", alert: "orange", status: "WATCH", url: "https://volcano.si.edu/volcano.cfm?vn=263300" },
            { name: "Nevado del Ruiz", country: "Colombia", alert: "yellow", status: "ADVISORY", url: "https://volcano.si.edu/volcano.cfm?vn=351020" },
            { name: "Stromboli", country: "Italy", alert: "yellow", status: "ADVISORY", url: "https://volcano.si.edu/volcano.cfm?vn=211040" }
        ];

        function renderVolcanoes() {
            const list = document.getElementById('volcano-list');
            if (!list) return;
            
            list.innerHTML = '';
            let highAlertCount = 0;
            
            GOLDEN_VOLCANOES.forEach(v => {
                let alertColor;
                let statusColor;
                if (v.alert === 'red') {
                    alertColor = '#ef4444';
                    statusColor = 'red';
                    highAlertCount++;
                } else if (v.alert === 'orange') {
                    alertColor = '#f97316';
                    statusColor = 'orange';
                    highAlertCount++;
                } else {
                    alertColor = '#eab308';
                    statusColor = 'yellow';
                }
                
                const item = document.createElement('div');
                item.className = 'volcano-item';
                item.style.borderLeftColor = alertColor;
                item.onclick = () => window.open(v.url, '_blank');
                item.innerHTML = `
                    <span class="volcano-name">🌋 ${v.name} (${v.country})</span>
                    <span class="volcano-status" style="background: ${alertColor}20; color: ${alertColor};">${v.status}</span>
                `;
                list.appendChild(item);
            });
            
            document.getElementById('volcano-total').innerText = GOLDEN_VOLCANOES.length;
            document.getElementById('volcano-alert').innerText = highAlertCount;
        }

        async function fetchEarthquakes() {
            try {
                const response = await fetch('https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson');
                const data = await response.json();
                const quakes = data.features.filter(q => q.properties.mag >= 2.5).slice(0,10);
                
                document.getElementById('quake-total').innerText = data.features.length;
                const strongest = Math.max(...data.features.map(q => q.properties.mag || 0));
                document.getElementById('quake-strongest').innerHTML = strongest.toFixed(1) + ' M';
                
                const list = document.getElementById('quake-list');
                list.innerHTML = '';
                
                quakes.forEach(q => {
                    const mag = q.properties.mag || 0;
                    const place = q.properties.place || 'Unknown';
                    const time = new Date(q.properties.time).toLocaleTimeString();
                    const color = mag >= 6 ? '#ef4444' : mag >= 4.5 ? '#f97316' : '#4ade80';
                    
                    const item = document.createElement('div');
                    item.className = 'quake-item';
                    item.style.borderLeftColor = color;
                    item.onclick = () => window.open('https://earthquake.usgs.gov/earthquakes/map/', '_blank');
                    item.innerHTML = `<span class="quake-magnitude" style="color:${color};">${mag.toFixed(1)}</span>
                                      <span class="quake-location">${place}</span>
                                      <span class="quake-time">${time}</span>`;
                    list.appendChild(item);
                });
            } catch (e) { console.error('Earthquake fetch failed:', e); }
        }

        function updateMoon() {
            const now = Date.now();
            const refNewMoon = Date.UTC(2024, 3, 8, 18, 20, 0);
            const synodicMonth = 29.530588853;
            const daysSince = (now - refNewMoon) / (1000 * 60 * 60 * 24);
            const age = ((daysSince % synodicMonth) + synodicMonth) % synodicMonth;
            const phase = age / synodicMonth;
            const illumination = (1 - Math.cos(phase * 2 * Math.PI)) / 2 * 100;
            const thickness = illumination * 31 / 100;
            
            let icon, phaseName;
            if (age < 1) { icon = '🌑'; phaseName = 'New Moon'; }
            else if (age < 7.4) { icon = '🌒'; phaseName = 'Waxing Crescent'; }
            else if (age < 14.8) { icon = '🌓'; phaseName = 'First Quarter'; }
            else if (age < 22.1) { icon = '🌔'; phaseName = 'Waxing Gibbous'; }
            else if (age < 29.5) { icon = '🌕'; phaseName = 'Full Moon'; }
            else { icon = '🌘'; phaseName = 'Waning Crescent'; }
            
            document.getElementById('moon-icon').innerText = icon;
            document.getElementById('moon-phase-name').innerText = phaseName;
            document.getElementById('moon-illumination').innerText = illumination.toFixed(1) + '%';
            document.getElementById('moon-thickness').innerText = thickness.toFixed(1) + "'";
            document.getElementById('moon-age').innerText = age.toFixed(1) + 'd';
        }

        function updateTime() {
            const now = new Date();
            const dateStr = now.toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' });
            document.getElementById('gregorian-date').innerText = '📅 ' + dateStr;
            document.getElementById('gregorian-date-full').innerText = dateStr;
            
            const utc = now.getUTCHours().toString().padStart(2,'0') + ':' +
                       now.getUTCMinutes().toString().padStart(2,'0') + ':' +
                       now.getUTCSeconds().toString().padStart(2,'0');
            document.getElementById('utc-clock').innerText = '🌐 ' + utc;
            document.getElementById('utc-clock-full').innerText = utc;
            
            const mecca = new Date(now.getTime() + (3 * 60 * 60 * 1000));
            const meccaTime = mecca.getUTCHours().toString().padStart(2,'0') + ':' +
                              mecca.getUTCMinutes().toString().padStart(2,'0') + ':' +
                              mecca.getUTCSeconds().toString().padStart(2,'0');
            document.getElementById('mecca-clock').innerText = '🕋 ' + meccaTime;
            document.getElementById('mecca-clock-full').innerText = meccaTime;
            
            const hijri = new Intl.DateTimeFormat('en-TN-u-ca-islamic', { day:'numeric', month:'long', year:'numeric' }).format(now);
            document.getElementById('hijri-date').innerText = hijri;
        }

        function updateTicker() {
            const quake = document.getElementById('quake-strongest')?.innerText || '0M';
            const volcano = document.getElementById('volcano-alert')?.innerText || '0';
            const ticker = document.getElementById('bottom-ticker');
            if (ticker) {
                ticker.innerHTML = `<div class="ticker-content">
                    <span class="ticker-item"><i class="fas fa-globe"></i> TRIO SEAL Observatory Active</span>
                    <span class="ticker-item"><i class="fas fa-fire"></i> Volcano Alerts: <span>${volcano}</span></span>
                    <span class="ticker-item"><i class="fas fa-waveform"></i> Strongest Quake: <span>${quake}</span></span>
                    <span class="ticker-item"><i class="fas fa-moon"></i> Moon Phase: <span id="ticker-moon">--</span></span>
                </div>`;
            }
            const moonIcon = document.getElementById('moon-icon')?.innerText || '🌑';
            const tickerMoon = document.getElementById('ticker-moon');
            if (tickerMoon) tickerMoon.innerText = moonIcon;
        }

        function toggleLanguageMenu() {
            const menu = document.getElementById('language-menu');
            menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
        }

        function setLanguage(lang) {
            document.getElementById('current-lang').innerText = lang.toUpperCase();
            document.getElementById('language-menu').style.display = 'none';
            const texts = {
                en: { volcano: 'Active Volcanoes', alert: 'High Alert', quakeTotal: 'Total', strongest: 'Strongest', latest: 'Latest' },
                ar: { volcano: 'براكين نشطة', alert: 'إنذار عالي', quakeTotal: 'المجموع', strongest: 'الأقوى', latest: 'الأحدث' }
            };
            const t = texts[lang];
            if (t) {
                document.querySelectorAll('.volcano-stat div:last-child').forEach((el, i) => {
                    if (i === 0) el.innerText = t.volcano;
                    if (i === 1) el.innerText = t.alert;
                });
                document.querySelectorAll('.quake-stat div:last-child').forEach((el, i) => {
                    if (i === 0) el.innerText = t.quakeTotal;
                    if (i === 1) el.innerText = t.strongest;
                    if (i === 2) el.innerText = t.latest;
                });
            }
        }

        document.addEventListener('click', function(e) {
            const card = e.target.closest('.obs-card[data-link]');
            if (card) {
                const url = card.getAttribute('data-link');
                if (url) window.open(url, '_blank');
            }
            const moon = e.target.closest('#moon-card');
            if (moon) window.open('https://www.timeanddate.com/moon/', '_blank');
            const footer = e.target.closest('.footer');
            if (footer && !e.target.closest('a')) window.open('https://github.com/sidichaker1-beep/Trio-seal', '_blank');
        });

        document.addEventListener('click', function(e) {
            if (!e.target.closest('.language-selector')) {
                document.getElementById('language-menu').style.display = 'none';
            }
        });

        renderVolcanoes();
        fetchEarthquakes();
        updateMoon();
        updateTime();
        updateTicker();
        
        setInterval(() => { updateTime(); updateMoon(); updateTicker(); }, 1000);
        setInterval(() => { fetchEarthquakes(); }, 30000);
        
        const newsItems = ['🌋 Fuego Volcano remains at WARNING level', '🌊 Pacific Ring of Fire active', '🌀 Solar flare activity moderate', '🌕 Moon approaching Full phase', '📡 All systems operational'];
        let newsIdx = 0;
        setInterval(() => {
            const ticker = document.getElementById('news-ticker');
            if (ticker) {
                newsIdx = (newsIdx + 1) % newsItems.length;
                ticker.innerHTML = `<span>${newsItems[newsIdx]}</span>`.repeat(3);
            }
        }, 5000);
        document.getElementById('news-ticker').innerHTML = `<span>${newsItems[0]}</span>`.repeat(3);
        
        // Dynamic values for cosmic indicators
        setInterval(() => {
            document.getElementById('taqabul-value').innerText = (23.5 + Math.sin(Date.now() / 10000) * 0.5).toFixed(2);
            document.getElementById('closure-value').innerText = (0.842 + Math.sin(Date.now() / 15000) * 0.02).toFixed(3);
            document.getElementById('balance-value').innerText = (1.27 + Math.sin(Date.now() / 20000) * 0.01).toFixed(3);
        }, 2000);
    </script>
</body>
</html>
