<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TRIO SEAL · Cosmic Observatory</title>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg-dark: #0a0f1a;
            --card-bg: rgba(15, 43, 79, 0.85);
            --card-border: rgba(255, 215, 0, 0.3);
            --text-glow: #ffd700;
            --text-live: #4ade80;
            --text-alert: #ef4444;
            --text-warning: #f97316;
            --text-secondary: #94a3b8;
            --shadow-glow: 0 0 20px rgba(255, 215, 0, 0.3);
            --shadow-red: 0 0 20px rgba(239, 68, 68, 0.3);
        }

        body {
            background: var(--bg-dark);
            color: #fff;
            font-family: 'Orbitron', sans-serif;
            min-height: 100vh;
            padding: 20px;
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(2px 2px at 20px 30px, #fff, rgba(0,0,0,0)),
                        radial-gradient(2px 2px at 40px 70px, #fff, rgba(0,0,0,0)),
                        radial-gradient(2px 2px at 80px 120px, #fff, rgba(0,0,0,0));
            background-size: 200px 200px;
            opacity: 0.3;
            pointer-events: none;
            z-index: -1;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        /* ===== HEADER ===== */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 2rem;
            margin-bottom: 2rem;
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
            border-radius: 15px;
            flex-wrap: wrap;
            gap: 15px;
        }

        .logo {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-glow);
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
            cursor: pointer;
        }

        .logo:hover {
            transform: scale(1.05);
        }

        .time-info {
            display: flex;
            gap: 2rem;
            font-family: 'Courier New', monospace;
            color: var(--text-live);
        }

        .language-selector {
            position: relative;
        }

        .lang-btn {
            background: transparent;
            border: 1px solid var(--card-border);
            color: var(--text-glow);
            padding: 0.5rem 1rem;
            border-radius: 8px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-family: 'Orbitron', sans-serif;
            backdrop-filter: blur(5px);
        }

        .lang-menu {
            position: absolute;
            top: 100%;
            right: 0;
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
            border-radius: 8px;
            display: none;
            z-index: 100;
            min-width: 150px;
            margin-top: 5px;
        }

        .lang-option {
            padding: 0.7rem 1rem;
            cursor: pointer;
            border-bottom: 1px solid rgba(255, 215, 0, 0.2);
        }

        .lang-option:hover {
            background: rgba(255, 215, 0, 0.2);
        }

        /* ===== NEWS TICKER ===== */
        .news-ticker {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
            border-radius: 10px;
            padding: 10px 20px;
            margin-bottom: 20px;
            overflow: hidden;
            white-space: nowrap;
            position: relative;
        }

        .news-ticker-content {
            display: inline-block;
            animation: ticker 30s linear infinite;
            color: var(--text-live);
        }

        .news-ticker-content span {
            margin-right: 30px;
            color: white;
        }

        @keyframes ticker {
            0% { transform: translateX(100%); }
            100% { transform: translateX(-100%); }
        }

        /* ===== COSMIC TIME BAR ===== */
        #cosmic-time-bar {
            display: flex;
            justify-content: space-around;
            padding: 12px 20px;
            margin-bottom: 20px;
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
            border-radius: 60px;
            font-family: 'Courier New', monospace;
            font-weight: bold;
            flex-wrap: wrap;
            gap: 10px;
        }

        #cosmic-time-bar span { color: white; }
        #cosmic-time-bar .utc-clock { color: var(--text-live); }
        #cosmic-time-bar .mecca-clock { color: var(--text-glow); }

        /* ===== GRID LAYOUTS ===== */
        .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 20px; }
        .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 20px; }
        .grid-5 { display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; margin-bottom: 20px; }

        @media (max-width: 1200px) {
            .grid-5, .grid-4 { grid-template-columns: repeat(2, 1fr); }
        }
        @media (max-width: 768px) {
            .grid-3, .grid-5, .grid-4 { grid-template-columns: 1fr; }
        }

        /* ===== OBSERVATORY CARDS ===== */
        .obs-card {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
            border-radius: 20px;
            padding: 1.5rem;
            transition: all 0.3s ease;
            cursor: pointer;
            position: relative;
            overflow: hidden;
            min-height: 250px;
            display: flex;
            flex-direction: column;
        }

        /* منع النقر على العناصر الداخلية */
        .obs-card img, .obs-card span, .obs-card div {
            pointer-events: none;
        }

        .obs-card[data-link] {
            cursor: pointer;
        }

        .obs-card[data-link]:hover {
            transform: translateY(-6px) scale(1.02);
            border-color: var(--text-glow);
            box-shadow: var(--shadow-glow);
        }

        .obs-card:not([data-link]):hover {
            transform: none;
            box-shadow: none;
            border-color: var(--card-border);
        }

        .obs-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
            transition: left 0.5s ease;
        }

        .obs-card:hover::before { left: 100%; }

        .obs-card.alert {
            border-color: var(--text-alert);
            box-shadow: var(--shadow-red);
            animation: shake 0.5s ease-in-out;
        }

        .obs-card.glow {
            border-color: var(--text-glow);
            box-shadow: 0 0 30px var(--text-glow);
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-5px); }
            75% { transform: translateX(5px); }
        }

        .obs-image {
            width: 100%;
            height: 120px;
            object-fit: cover;
            border-radius: 10px;
            margin-bottom: 1rem;
            border: 1px solid var(--card-border);
            transition: all 0.3s ease;
        }

        .obs-title {
            color: var(--text-glow);
            font-size: 1.1rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
            cursor: help;
            border-bottom: 1px dashed var(--text-glow);
            display: inline-block;
        }

        .obs-value {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--text-live);
            margin-bottom: 0.3rem;
            transition: all 0.3s ease;
        }

        .obs-unit {
            color: var(--text-secondary);
            font-size: 0.8rem;
        }

        .source-btn {
            margin-top: auto;
            background: transparent;
            border: 1px solid var(--card-border);
            color: var(--text-live);
            padding: 8px;
            border-radius: 8px;
            cursor: pointer;
            font-family: 'Orbitron', sans-serif;
            font-size: 0.8rem;
            transition: all 0.3s ease;
            width: 100%;
            pointer-events: auto; /* الأزرار تبقى قابلة للنقر */
        }

        .source-btn:hover {
            background: var(--text-glow);
            color: var(--bg-dark);
            border-color: var(--text-glow);
        }

        /* ===== TOOLTIP ===== */
        [data-tooltip] {
            position: relative;
            cursor: help;
        }

        [data-tooltip]:before {
            content: attr(data-tooltip);
            position: absolute;
            bottom: 100%;
            left: 50%;
            transform: translateX(-50%);
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--text-glow);
            color: white;
            padding: 5px 10px;
            border-radius: 5px;
            font-size: 0.8rem;
            white-space: nowrap;
            z-index: 1000;
            margin-bottom: 5px;
            display: none;
        }

        [data-tooltip]:hover:before {
            display: block;
        }

        /* ===== MOON PHASE ===== */
        .moon-phase {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
            border-radius: 30px;
            padding: 2rem;
            margin: 2rem 0;
            display: flex;
            align-items: center;
            gap: 3rem;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .moon-phase:hover {
            border-color: var(--text-glow);
            box-shadow: var(--shadow-glow);
        }

        .moon-icon {
            font-size: 5rem;
            transition: all 0.3s ease;
        }

        .moon-icon.pulse {
            animation: pulse-red 1s infinite;
            filter: drop-shadow(0 0 15px var(--text-alert));
        }

        @keyframes pulse-red {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }

        .moon-stats { flex: 1; }
        .moon-title { font-size: 1.5rem; font-weight: 700; color: var(--text-glow); margin-bottom: 1rem; }
        .moon-grid { display: flex; gap: 3rem; flex-wrap: wrap; }
        .moon-item { text-align: center; }
        .moon-item .value { font-size: 1.5rem; font-weight: 700; color: var(--text-live); }
        .moon-item .label { color: var(--text-secondary); font-size: 0.8rem; }

        /* ===== STATUS INDICATORS ===== */
        .status-dot {
            display: inline-block;
            width: 10px;
            height: 10px;
            border-radius: 50%;
            margin-right: 5px;
        }
        .status-dot.green { background: var(--text-live); box-shadow: 0 0 10px var(--text-live); }
        .status-dot.orange { background: var(--text-warning); box-shadow: 0 0 10px var(--text-warning); }
        .status-dot.red { background: var(--text-alert); box-shadow: 0 0 10px var(--text-alert); }

        /* ===== EARTHQUAKE SECTION ===== */
        .earthquake-stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .quake-stat {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 15px;
            padding: 1rem;
            text-align: center;
            cursor: pointer;
        }

        .quake-stat .number { font-size: 2rem; font-weight: bold; color: var(--text-glow); }

        .quake-list {
            max-height: 300px;
            overflow-y: auto;
            margin-bottom: 1rem;
        }

        .quake-item {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 12px;
            padding: 0.8rem 1rem;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            border-left: 5px solid;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .quake-item:hover { transform: translateX(5px); }
        .quake-magnitude { font-size: 1.4rem; font-weight: bold; min-width: 60px; }
        .quake-location { flex: 1; }
        .quake-time { color: var(--text-secondary); font-size: 0.8rem; }

        /* ===== VOLCANO SECTION ===== */
        .volcano-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .volcano-stat {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 15px;
            padding: 1rem;
            text-align: center;
            cursor: pointer;
        }

        .volcano-stat .number { font-size: 2rem; font-weight: bold; color: var(--text-glow); }

        .volcano-list {
            max-height: 300px;
            overflow-y: auto;
        }

        .volcano-item {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 12px;
            padding: 0.8rem 1rem;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 1rem;
            border-left: 5px solid;
            cursor: pointer;
            transition: transform 0.2s;
        }

        .volcano-item:hover { transform: translateX(5px); }
        .volcano-icon { font-size: 1.4rem; min-width: 60px; color: var(--text-warning); }
        .volcano-name { flex: 1; }
        .volcano-desc { color: var(--text-secondary); font-size: 0.8rem; }

        /* ===== BOTTOM TICKER ===== */
        .bottom-ticker {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border-top: 1px solid var(--card-border);
            padding: 10px 0;
            overflow: hidden;
            white-space: nowrap;
            z-index: 1000;
        }

        .ticker-content {
            display: inline-block;
            animation: ticker 40s linear infinite;
        }

        .ticker-item {
            display: inline-block;
            margin-right: 40px;
            color: white;
            font-size: 0.9rem;
            cursor: pointer;
        }

        .ticker-item i { margin-right: 5px; color: var(--text-glow); }
        .ticker-item span { color: var(--text-live); font-weight: bold; }

        /* ===== FOOTER ===== */
        .footer {
            margin-top: 4rem;
            padding: 1.5rem;
            text-align: center;
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--card-border);
            border-radius: 20px;
            margin-bottom: 60px;
            cursor: pointer;
        }

        .footer .name { color: var(--text-glow); font-weight: 700; }
        .footer a { color: var(--text-live); text-decoration: none; }

        .section-title {
            color: var(--text-glow);
            font-size: 1.8rem;
            margin: 2rem 0 1rem;
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.3);
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <div class="logo" data-link="https://github.com/sidichaker1-beep/Trio-seal">🌌 TRIO SEAL</div>
            <div class="time-info">
                <span id="gregorian-date">📅 --</span>
                <span id="utc-clock">🌐 00:00:00</span>
                <span id="mecca-clock">🕋 00:00:00</span>
            </div>
            <div class="language-selector">
                <button class="lang-btn" onclick="toggleLanguageMenu()">
                    🌐 <span id="current-lang">EN</span> <span style="font-size:0.8rem;">▼</span>
                </button>
                <div id="language-menu" class="lang-menu">
                    <div class="lang-option" onclick="setLanguage('en')">🇬🇧 EN</div>
                    <div class="lang-option" onclick="setLanguage('ar')">🇸🇦 AR</div>
                </div>
            </div>
        </div>

        <!-- News Ticker -->
        <div class="news-ticker">
            <div class="news-ticker-content" id="news-ticker"></div>
        </div>

        <!-- Cosmic Time Bar -->
        <div id="cosmic-time-bar">
            <div>📅 <span id="gregorian-date-full">--</span> · <span id="hijri-date">--</span></div>
            <div>🌐 UTC: <span class="utc-clock" id="utc-clock-full">00:00:00</span></div>
            <div>🕋 Mecca: <span class="mecca-clock" id="mecca-clock-full">00:00:00</span></div>
        </div>

        <!-- Core Indicators -->
        <div class="grid-3">
            <div class="obs-card" data-link="https://www.timeanddate.com/astronomy/moon/mecca.html">
                <span class="obs-title">🕋 Taqābul</span>
                <span class="obs-value" id="taqabul-value">23.50</span>
                <span class="obs-unit">Angle</span>
            </div>
            <div class="obs-card" data-link="https://earthquake.usgs.gov">
                <span class="obs-title">🌀 Closure</span>
                <span class="obs-value" id="closure-value">0.842</span>
                <span class="obs-unit">RS</span>
            </div>
            <div class="obs-card" data-link="https://www.noaa.gov">
                <span class="obs-title">⚖️ Balance</span>
                <span class="obs-value" id="balance-value">1.270</span>
                <span class="obs-unit">α_stab</span>
            </div>
        </div>

        <!-- Moon Phase -->
        <div class="moon-phase" id="moon-card" data-link="https://www.timeanddate.com/moon/">
            <div class="moon-icon" id="moon-icon">🌑</div>
            <div class="moon-stats">
                <div class="moon-title" id="moon-phase-name">New Moon</div>
                <div class="moon-grid">
                    <div class="moon-item">
                        <div class="value" id="moon-illumination">0%</div>
                        <div class="label">Illumination</div>
                    </div>
                    <div class="moon-item">
                        <div class="value" id="moon-thickness">0'</div>
                        <div class="label">Thickness</div>
                    </div>
                    <div class="moon-item">
                        <div class="value" id="moon-age">0d</div>
                        <div class="label">Age</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Observatory Cards -->
        <h2 class="section-title">☀️ Solar Observatory</h2>
        <div class="grid-4">
            <div class="obs-card" data-link="https://services.swpc.noaa.gov/json/ovation_aurora_latest.json">
                <img class="obs-image" id="aurora-img" src="https://services.swpc.noaa.gov/images/aurora-forecast/latest.jpg" alt="Aurora">
                <span class="obs-title">Aurora Oval</span>
            </div>
            <div class="obs-card" data-link="https://www.swpc.noaa.gov/products/planetary-k-index">
                <img class="obs-image" id="kp-img" src="https://services.swpc.noaa.gov/images/planetary-k-index.gif" alt="Kp">
                <span class="obs-title">Kp Index</span>
            </div>
            <div class="obs-card" data-link="https://solarham.com/cmetracking.htm">
                <img class="obs-image" id="cme-img" src="https://solarham.com/images/cme_latest.png" alt="CME">
                <span class="obs-title">CME Tracking</span>
            </div>
            <div class="obs-card" data-link="https://www.swpc.noaa.gov/products/goes-x-ray-flux">
                <img class="obs-image" id="xray-img" src="https://services.swpc.noaa.gov/images/goes-xray-flux-latest.png" alt="X-Ray">
                <span class="obs-title">X-Ray Flux</span>
            </div>
        </div>

        <!-- Daily Solar Image -->
        <div class="obs-card" data-link="https://sdo.gsfc.nasa.gov/data/" style="margin: 1rem 0;">
            <img class="obs-image" id="daily-solar-img" src="https://sdo.gsfc.nasa.gov/assets/img/latest/latest_512_1024.jpg" alt="Daily Solar">
            <span class="obs-title">☀️ Today's Sun</span>
        </div>

        <!-- Volcano Observatory -->
        <h2 class="section-title">🌋 Live Volcano Observatory</h2>
        <div class="obs-card" data-link="https://volcano.si.edu/">
            <div class="volcano-stats">
                <div class="volcano-stat"><span class="number" id="volcano-total">0</span><div>Active Volcanoes</div></div>
                <div class="volcano-stat"><span class="number" id="volcano-alert">0</span><div>High Alert</div></div>
            </div>
            <div id="volcano-list" class="volcano-list"></div>
        </div>

        <!-- Earthquake Observatory -->
        <h2 class="section-title">🌋 Live Earthquake Observatory</h2>
        <div class="obs-card" data-link="https://earthquake.usgs.gov/earthquakes/map/">
            <div class="earthquake-stats">
                <div class="quake-stat"><span class="number" id="quake-total">0</span><div>Total</div></div>
                <div class="quake-stat"><span class="number" id="quake-strongest">0</span><div>Strongest</div></div>
                <div class="quake-stat"><span class="number" id="quake-latest">0</span><div>Latest</div></div>
            </div>
            <div id="quake-list" class="quake-list"></div>
        </div>

        <!-- Footer -->
        <div class="footer" data-link="https://github.com/sidichaker1-beep/Trio-seal">
            <div class="name">Hicham Chigar · هشام شيكر</div>
            <div style="margin: 0.5rem 0;">Mizan al-Malakut v7.3 · Calibrated by Gemini · DeepSeek · GPT</div>
            <div>DOI: <a href="https://doi.org/10.5281/zenodo.19076840" target="_blank">10.5281/zenodo.19076840</a></div>
        </div>
    </div>

    <!-- Bottom Ticker -->
    <div class="bottom-ticker">
        <div class="ticker-content" id="bottom-ticker"></div>
    </div>

    <script>
        // ===== CARD CLICK HANDLER =====
        document.addEventListener('click', function(e) {
            const card = e.target.closest('.obs-card[data-link]');
            if (card) {
                const url = card.getAttribute('data-link');
                if (url) window.open(url, '_blank');
            }
        });

        // ===== MOON PHASE CALCULATION =====
        function updateMoon() {
            const now = Date.now();
            const refNewMoon = Date.UTC(2024, 3, 8, 18, 20, 0);
            const synodicMonth = 29.530588853;
            const daysSince = (now - refNewMoon) / (1000 * 60 * 60 * 24);
            const age = ((daysSince % synodicMonth) + synodicMonth) % synodicMonth;
            const phase = age / synodicMonth;
            const illumination = (1 - Math.cos(phase * 2 * Math.PI)) / 2 * 100;
            const thickness = illumination * 31 / 100;
            
            let icon;
            if (age < 1) icon = '🌑';
            else if (age < 7.4) icon = '🌒';
            else if (age < 14.8) icon = '🌓';
            else if (age < 22.1) icon = '🌔';
            else if (age < 29.5) icon = '🌕';
            else icon = '🌘';
            
            document.getElementById('moon-icon').innerText = icon;
            document.getElementById('moon-illumination').innerText = illumination.toFixed(1) + '%';
            document.getElementById('moon-thickness').innerText = thickness.toFixed(1) + "'";
            document.getElementById('moon-age').innerText = age.toFixed(1) + 'd';
        }

        // ===== TIME UPDATE =====
        function updateTime() {
            const now = new Date();
            document.getElementById('gregorian-date').innerText = now.toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' });
            document.getElementById('gregorian-date-full').innerText = document.getElementById('gregorian-date').innerText;
            
            const utc = now.getUTCHours().toString().padStart(2,'0') + ':' +
                       now.getUTCMinutes().toString().padStart(2,'0') + ':' +
                       now.getUTCSeconds().toString().padStart(2,'0');
            document.getElementById('utc-clock').innerText = utc;
            document.getElementById('utc-clock-full').innerText = utc;
            
            const mecca = new Date(now.getTime() + (3 * 60 * 60 * 1000));
            const meccaTime = mecca.getUTCHours().toString().padStart(2,'0') + ':' +
                              mecca.getUTCMinutes().toString().padStart(2,'0') + ':' +
                              mecca.getUTCSeconds().toString().padStart(2,'0');
            document.getElementById('mecca-clock').innerText = meccaTime;
            document.getElementById('mecca-clock-full').innerText = meccaTime;
        }

        // ===== EARTHQUAKES =====
        async function fetchEarthquakes() {
            try {
                const response = await fetch('https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson');
                const data = await response.json();
                const quakes = data.features.filter(q => q.properties.mag >= 2.5).slice(0,10);
                
                document.getElementById('quake-total').innerText = data.features.length;
                document.getElementById('quake-strongest').innerText = quakes[0]?.properties.mag?.toFixed(1) + ' M';
                
                const list = document.getElementById('quake-list');
                list.innerHTML = '';
                
                quakes.forEach(q => {
                    const mag = q.properties.mag || 0;
                    const place = q.properties.place || 'Unknown';
                    const time = new Date(q.properties.time).toLocaleString();
                    const color = mag >= 6 ? '#ef4444' : mag >= 4.5 ? '#f97316' : '#4ade80';
                    
                    const item = document.createElement('div');
                    item.className = 'quake-item';
                    item.style.borderLeftColor = color;
                    item.innerHTML = `<span class="quake-magnitude" style="color:${color};">${mag.toFixed(1)}</span>
                                      <span class="quake-location">${place}</span>
                                      <span class="quake-time">${time}</span>`;
                    list.appendChild(item);
                });
            } catch (e) { console.error('Failed to fetch earthquakes:', e); }
        }

        // ===== VOLCANOES =====
        async function fetchVolcanoes() {
            try {
                // Note: This is a mock API - replace with actual Smithsonian API when available
                const mockVolcanoes = [
                    { name: 'Kilauea', country: 'Hawaii', status: 'Active', alert: 'Orange' },
                    { name: 'Etna', country: 'Italy', status: 'Active', alert: 'Yellow' },
                    { name: 'Fuego', country: 'Guatemala', status: 'Erupting', alert: 'Red' },
                    { name: 'Sakurajima', country: 'Japan', status: 'Active', alert: 'Orange' },
                    { name: 'Popocatépetl', country: 'Mexico', status: 'Active', alert: 'Yellow' }
                ];
                
                document.getElementById('volcano-total').innerText = mockVolcanoes.length;
                document.getElementById('volcano-alert').innerText = mockVolcanoes.filter(v => v.alert === 'Red').length;
                
                const list = document.getElementById('volcano-list');
                list.innerHTML = '';
                
                mockVolcanoes.forEach(v => {
                    const color = v.alert === 'Red' ? '#ef4444' : v.alert === 'Orange' ? '#f97316' : '#4ade80';
                    
                    const item = document.createElement('div');
                    item.className = 'volcano-item';
                    item.style.borderLeftColor = color;
                    item.onclick = () => window.open('https://volcano.si.edu/', '_blank');
                    item.innerHTML = `<span class="volcano-icon">🌋</span>
                                      <span class="volcano-name">${v.name}, ${v.country}</span>
                                      <span class="volcano-desc">${v.status}</span>`;
                    list.appendChild(item);
                });
            } catch (e) { console.error('Failed to fetch volcanoes:', e); }
        }

        // ===== LANGUAGE =====
        function setLanguage(lang) {
            document.documentElement.dir = lang === 'ar' ? 'rtl' : 'ltr';
            document.getElementById('current-lang').innerText = lang.toUpperCase();
            document.getElementById('language-menu').style.display = 'none';
        }

        function toggleLanguageMenu() {
            const menu = document.getElementById('language-menu');
            menu.style.display = menu.style.display === 'block' ? 'none' : 'block';
        }

        // ===== INIT =====
        window.addEventListener('DOMContentLoaded', () => {
            updateTime();
            updateMoon();
            fetchEarthquakes();
            fetchVolcanoes();
            
            setInterval(() => updateTime(), 1000);
            setInterval(() => updateMoon(), 60000);
            setInterval(() => fetchEarthquakes(), 60000);
            setInterval(() => fetchVolcanoes(), 3600000); // تحديث كل ساعة
            
            document.getElementById('news-ticker').innerHTML = [
                "⚠️ M2.7 flare from AR 4392",
                "🌊 CME expected March 19",
                "📡 Type II Radio Emission",
                "🛰️ Minor R1 blackout"
            ].map(n => `<span>${n}</span>`).join(' • ');
        });

        // Close language menu when clicking outside
        document.addEventListener('click', function(event) {
            const menu = document.getElementById('language-menu');
            const btn = document.querySelector('.lang-btn');
            if (!btn.contains(event.target) && !menu.contains(event.target)) menu.style.display = 'none';
        });
    </script>
</body>
</html>
